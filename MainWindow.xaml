<Window x:Class="computerclub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:computerclub.Controls"
        Title="Computer Club Admin Panel" Height="950" Width="1650" 
        WindowStartupLocation="CenterScreen" Background="#F0F2F5"
        FontFamily="Segoe UI" FontSize="13"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        >

    <Window.Resources>
        <!-- Стиль для заголовков GroupBox -->
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Стиль для кнопок -->
        <Style TargetType="Button" x:Key="AddButton">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="32"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45a049"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="EditButton">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="32"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="DeleteButton">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="32"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="StartButton">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="32"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45a049"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="EndButton">
            <Setter Property="Background" Value="#FF9800"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="32"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FB8C00"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для заголовков GroupBox и текста в панелях -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <!-- Стиль для TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,5,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Стиль для TextBlock подписей -->
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="0" 
                                Margin="0,2,0,2"
                                Padding="18,12"
                                CornerRadius="8,0,0,8">
                            <ContentPresenter ContentSource="Header" 
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2196F3"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для Border (панель управления) -->
        <Style TargetType="Border" x:Key="ControlPanel">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <!-- Стиль для WrapPanel -->
        <Style TargetType="WrapPanel">
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- Стиль для StackPanel внутри панели управления -->
        <Style TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,20,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок окна с кнопками управления -->
        <Border Background="#2196F3" Grid.Row="0">
            <Grid>
                <TextBlock Text="COMPUTER CLUB MANAGEMENT SYSTEM" 
                           FontSize="18" FontWeight="Bold" Foreground="White" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Button Content="−" Width="35" Height="35" FontSize="18" FontWeight="Bold" 
                            Foreground="White" Background="Transparent" BorderThickness="0"
                            Click="MinimizeWindow_Click" Cursor="Hand"/>
                    <Button Content="□" Width="35" Height="35" FontSize="14" FontWeight="Bold" 
                            Foreground="White" Background="Transparent" BorderThickness="0"
                            Click="MaximizeWindow_Click" Cursor="Hand"/>
                    <Button Content="✕" Width="35" Height="35" FontSize="16" FontWeight="Bold" 
                            Foreground="White" Background="Transparent" BorderThickness="0"
                            Click="CloseWindow_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="15">
            <TabControl x:Name="MainTabControl" TabStripPlacement="Left" Background="White">

                <!-- ==================== 1. КЛИЕНТЫ ==================== -->
                <TabItem Header="Клиенты">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="ClientFilter" FiltersChanged="ClientFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgClients" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgClients_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgClients_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Никнейм" Binding="{Binding Nickname}" Width="180"/>
                                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                                    <DataGridTextColumn Header="Баланс" Binding="{Binding Balance, StringFormat={}{0:F2}}" Width="120"/>
                                    <DataGridTextColumn Header="Ранг" Binding="{Binding Rank.RankName}" Width="130"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Никнейм"/>
                                    <TextBox x:Name="InpClientNick" Width="160"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Телефон"/>
                                    <TextBox x:Name="InpClientPhone" Width="140"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Баланс"/>
                                    <TextBox x:Name="InpClientBalance" Width="110"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Ранг"/>
                                    <ComboBox x:Name="CmbClientRank" Width="130" DisplayMemberPath="RankName" SelectedValuePath="RankId"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnClientAdd_Click"/>
                                    <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnClientEdit_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnClientDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 2. КОМПЬЮТЕРЫ ==================== -->
                <TabItem Header="Компьютеры">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="ComputerFilter" FiltersChanged="ComputerFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgComputers" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgComputers_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgComputers_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding ComputerName}" Width="180"/>
                                    <DataGridTextColumn Header="IP адрес" Binding="{Binding Ipaddress}" Width="140"/>
                                    <DataGridTextColumn Header="Зал" Binding="{Binding Hall.Name}" Width="140"/>
                                    <DataGridCheckBoxColumn Header="Доступен" Binding="{Binding IsAvailable}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Название ПК"/>
                                    <TextBox x:Name="InpComputerName" Width="140"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="IP адрес"/>
                                    <TextBox x:Name="InpComputerIP" Width="130"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Зал"/>
                                    <ComboBox x:Name="CmbComputerHall" Width="130" DisplayMemberPath="Name" SelectedValuePath="HallId"/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Center">
                                    <CheckBox x:Name="ChkComputerAvailable" Content="Доступен" Margin="0,0,10,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnComputerAdd_Click"/>
                                    <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnComputerEdit_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnComputerDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 3. ПРОДУКТЫ ==================== -->
                <TabItem Header="Продукты">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="ProductFilter" FiltersChanged="ProductFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgProducts" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgProducts_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgProducts_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding ProductName}" Width="200"/>
                                    <DataGridTextColumn Header="Категория" Binding="{Binding Category.CategoryName}" Width="140"/>
                                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="120"/>
                                    <DataGridTextColumn Header="Остаток" Binding="{Binding StockQuantity}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Название"/>
                                    <TextBox x:Name="InpProductName" Width="160"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Категория"/>
                                    <ComboBox x:Name="CmbProductCategory" Width="130" DisplayMemberPath="CategoryName" SelectedValuePath="CategoryId"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Цена"/>
                                    <TextBox x:Name="InpProductPrice" Width="110"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Остаток"/>
                                    <TextBox x:Name="InpProductStock" Width="90"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnProductAdd_Click"/>
                                    <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnProductEdit_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnProductDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 4. СОТРУДНИКИ ==================== -->
                <TabItem Header="Сотрудники">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="EmployeeFilter" FiltersChanged="EmployeeFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgEmployees" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgEmployees_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgEmployees_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="220"/>
                                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                                    <DataGridTextColumn Header="Должность" Binding="{Binding Position.Title}" Width="160"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="ФИО"/>
                                    <TextBox x:Name="InpEmployeeName" Width="200"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Телефон"/>
                                    <TextBox x:Name="InpEmployeePhone" Width="140"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Должность"/>
                                    <ComboBox x:Name="CmbEmployeePosition" Width="150" DisplayMemberPath="Title" SelectedValuePath="PositionId"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnEmployeeAdd_Click"/>
                                    <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnEmployeeEdit_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnEmployeeDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 5. ИГРЫ ==================== -->
                <TabItem Header="Игры">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="GameFilter" FiltersChanged="GameFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgGames" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgGames_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgGames_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="220"/>
                                    <DataGridTextColumn Header="Разработчик" Binding="{Binding Developer}" Width="220"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Название"/>
                                    <TextBox x:Name="InpGameTitle" Width="200"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Разработчик"/>
                                    <TextBox x:Name="InpGameDeveloper" Width="200"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnGameAdd_Click"/>
                                    <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnGameEdit_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnGameDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 6. ТАРИФЫ ==================== -->
                <TabItem Header="Тарифы">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="TariffFilter" FiltersChanged="TariffFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgTariffs" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgTariffs_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgTariffs_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding TariffName}" Width="180"/>
                                    <DataGridTextColumn Header="Зал" Binding="{Binding Hall.Name}" Width="140"/>
                                    <DataGridTextColumn Header="Длительность" Binding="{Binding DurationMinutes}" Width="120"/>
                                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Название"/>
                                    <TextBox x:Name="InpTariffName" Width="160"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Зал"/>
                                    <ComboBox x:Name="CmbTariffHall" Width="130" DisplayMemberPath="Name" SelectedValuePath="HallId"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Длительность (мин)"/>
                                    <TextBox x:Name="InpTariffDuration" Width="110"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Цена"/>
                                    <TextBox x:Name="InpTariffPrice" Width="110"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnTariffAdd_Click"/>
                                    <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnTariffEdit_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnTariffDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 7. СЕССИИ ==================== -->
                <TabItem Header="Сессии">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="SessionFilter" FiltersChanged="SessionFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgSessions" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgSessions_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="320" LoadingRow="DgSessions_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Клиент" Binding="{Binding Client.Nickname}" Width="140"/>
                                    <DataGridTextColumn Header="ПК" Binding="{Binding Computer.ComputerName}" Width="110"/>
                                    <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="140"/>
                                    <DataGridTextColumn Header="Тариф" Binding="{Binding Tariff.TariffName}" Width="130"/>
                                    <DataGridTextColumn Header="Начало" Binding="{Binding StartTime, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                                    <DataGridTextColumn Header="Конец" Binding="{Binding EndTime, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                                    <DataGridTextColumn Header="Стоимость" Binding="{Binding TotalCost, StringFormat={}{0:F2}}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <WrapPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Клиент"/>
                                        <ComboBox x:Name="CmbSessionClient" Width="130" DisplayMemberPath="Nickname" SelectedValuePath="ClientId"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="ПК"/>
                                        <ComboBox x:Name="CmbSessionComputer" Width="110" DisplayMemberPath="ComputerName" SelectedValuePath="ComputerId"
          SelectionChanged="CmbSessionComputer_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Сотрудник"/>
                                        <ComboBox x:Name="CmbSessionEmployee" Width="130" DisplayMemberPath="FullName" SelectedValuePath="EmployeeId"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Тариф"/>
                                        <ComboBox x:Name="CmbSessionTariff" Width="130" DisplayMemberPath="TariffName" SelectedValuePath="TariffId"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Оплата"/>
                                        <ComboBox x:Name="CmbSessionPayment" Width="130" DisplayMemberPath="MethodName" SelectedValuePath="PaymentMethodId"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                        <Button Content="Начать" Style="{StaticResource StartButton}" Click="BtnSessionAdd_Click"/>
                                        <Button Content="Завершить" Style="{StaticResource EndButton}" Click="BtnSessionEnd_Click"/>
                                        <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnSessionEdit_Click"/>
                                        <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnSessionDelete_Click"/>
                                    </StackPanel>
                                </WrapPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 8. ЗАЛЫ ==================== -->
                <TabItem Header="Залы">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="HallFilter" FiltersChanged="HallFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgHalls" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgHalls_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgHalls_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="220"/>
                                    <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="400"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Название"/>
                                    <TextBox x:Name="InpHallName" Width="160"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Описание"/>
                                    <TextBox x:Name="InpHallDesc" Width="260"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnHallAdd_Click"/>
                                    <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnHallEdit_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnHallDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 9. РАНГИ ==================== -->
                <TabItem Header="Ранги">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="RankFilter" FiltersChanged="RankFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgRanks" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgRanks_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgRanks_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding RankName}" Width="220"/>
                                    <DataGridTextColumn Header="Скидка %" Binding="{Binding DiscountPercent}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Название"/>
                                    <TextBox x:Name="InpRankName" Width="160"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Скидка %"/>
                                    <TextBox x:Name="InpRankDiscount" Width="110"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnRankAdd_Click"/>
                                    <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnRankEdit_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnRankDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 10. МЕТОДЫ ОПЛАТЫ ==================== -->
                <TabItem Header="Методы оплаты">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="PaymentMethodFilter" FiltersChanged="PaymentMethodFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgPaymentMethods" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgMethods_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgPaymentMethods_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Метод оплаты" Binding="{Binding MethodName}" Width="300"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Метод оплаты"/>
                                    <TextBox x:Name="InpMethodName" Width="220"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnMethodAdd_Click"/>
                                    <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnMethodEdit_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnMethodDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 11. КАТЕГОРИИ ==================== -->
                <TabItem Header="Категории">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="CategoryFilter" FiltersChanged="CategoryFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgCategories" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgCategories_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgCategories_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="300"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Категория"/>
                                    <TextBox x:Name="InpCategoryName" Width="220"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnCategoryAdd_Click"/>
                                    <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnCategoryEdit_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnCategoryDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 12. ДОЛЖНОСТИ ==================== -->
                <TabItem Header="Должности">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="PositionFilter" FiltersChanged="PositionFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgPositions" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgPositions_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgPositions_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Должность" Binding="{Binding Title}" Width="300"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Должность"/>
                                    <TextBox x:Name="InpPositionTitle" Width="220"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnPositionAdd_Click"/>
                                    <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnPositionEdit_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnPositionDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 13. ИГРЫ НА ПК ==================== -->
                <TabItem Header="Игры на ПК">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="ComputerGameFilter" FiltersChanged="ComputerGameFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgComputerGames" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgComputerGames_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgComputerGames_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Компьютер" Binding="{Binding Computer.ComputerName}" Width="200"/>
                                    <DataGridTextColumn Header="Игра" Binding="{Binding Game.Title}" Width="200"/>
                                    <DataGridTextColumn Header="Разработчик" Binding="{Binding Game.Developer}" Width="200"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Компьютер"/>
                                    <ComboBox x:Name="CmbComputerGameComputer" Width="160" DisplayMemberPath="ComputerName" SelectedValuePath="ComputerId"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Игра"/>
                                    <ComboBox x:Name="CmbComputerGameGame" Width="160" DisplayMemberPath="Title" SelectedValuePath="GameId"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                    <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnComputerGameAdd_Click"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnComputerGameDelete_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 14. ЗАКАЗЫ ==================== -->
                <TabItem Header="Заказы">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="OrderFilter" FiltersChanged="OrderFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgOrders" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgOrders_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgOrders_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Клиент" Binding="{Binding Session.Client.Nickname}" Width="160"/>
                                    <DataGridTextColumn Header="Компьютер" Binding="{Binding Session.Computer.ComputerName}" Width="130"/>
                                    <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="160"/>
                                    <DataGridTextColumn Header="Метод оплаты" Binding="{Binding PaymentMethod.MethodName}" Width="140"/>
                                    <DataGridTextColumn Header="Время заказа" Binding="{Binding OrderTime, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <WrapPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Клиент"/>
                                        <ComboBox x:Name="CmbOrderClient" Width="150" DisplayMemberPath="Nickname" SelectedValuePath="ClientId"
                                                  SelectionChanged="CmbOrderClient_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Компьютер"/>
                                        <ComboBox x:Name="CmbOrderComputer" Width="130" DisplayMemberPath="ComputerName" SelectedValuePath="ComputerId"
                                                  IsEnabled="False" SelectionChanged="CmbOrderComputer_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Сессия"/>
                                        <ComboBox x:Name="CmbOrderSession" Width="190" DisplayMemberPath="SessionInfo" SelectedValuePath="SessionId"
              SelectionChanged="CmbOrderSession_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Сотрудник"/>
                                        <ComboBox x:Name="CmbOrderEmployee" Width="150" DisplayMemberPath="FullName" SelectedValuePath="EmployeeId"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Оплата"/>
                                        <ComboBox x:Name="CmbOrderPayment" Width="140" DisplayMemberPath="MethodName" SelectedValuePath="PaymentMethodId"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                        <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnOrderAdd_Click"/>
                                        <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnOrderEdit_Click"/>
                                        <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnOrderDelete_Click"/>
                                    </StackPanel>
                                </WrapPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 15. ДЕТАЛИ ЗАКАЗОВ ==================== -->
                <TabItem Header="Детали заказов">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:FilterPanel x:Name="OrderDetailFilter" FiltersChanged="OrderDetailFilter_FiltersChanged"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid x:Name="DgOrderDetails" AutoGenerateColumns="False" IsReadOnly="True" 
                                      SelectionChanged="DgOrderDetails_SelectionChanged" CanUserSortColumns="True" 
                                      Background="White" MinHeight="350" LoadingRow="DgOrderDetails_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Клиент" Binding="{Binding Order.Session.Client.Nickname}" Width="160"/>
                                    <DataGridTextColumn Header="Товар" Binding="{Binding Product.ProductName}" Width="200"/>
                                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                                    <DataGridTextColumn Header="Цена" Binding="{Binding PriceAtPurchase, StringFormat={}{0:F2}}" Width="120"/>
                                    <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat={}{0:F2}}" Width="120"/>

                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>

                        <Border Style="{StaticResource ControlPanel}" Grid.Row="2">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <WrapPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Заказ"/>
                                        <ComboBox x:Name="CmbOrderDetailOrder" Width="260" DisplayMemberPath="OrderInfo" SelectedValuePath="OrderId"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Товар"/>
                                        <ComboBox x:Name="CmbOrderDetailProduct" Width="180" DisplayMemberPath="ProductName" SelectedValuePath="ProductId" 
              SelectionChanged="CmbOrderDetailProduct_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Количество"/>
                                        <TextBox x:Name="InpOrderDetailQuantity" Width="80" Text="1"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Цена"/>
                                        <TextBox x:Name="InpOrderDetailPrice" Width="110" IsReadOnly="True" Background="#F5F5F5"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,5">
                                        <Button Content="Добавить" Style="{StaticResource AddButton}" Click="BtnOrderDetailAdd_Click"/>
                                        <Button Content="Обновить" Style="{StaticResource EditButton}" Click="BtnOrderDetailEdit_Click"/>
                                        <Button Content="Удалить" Style="{StaticResource DeleteButton}" Click="BtnOrderDetailDelete_Click"/>
                                    </StackPanel>
                                </WrapPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ==================== 16. АНАЛИТИКА (SQL ЗАПРОСЫ) ==================== -->
                <TabItem Header="Аналитика">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Выбор запроса -->
                        <Border Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,10" Padding="0" Grid.Row="0">
                            <StackPanel>
                                <Border Background="#F5F5F5" Padding="10,8" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
                                    <TextBlock Text="Выберите аналитический запрос" FontWeight="SemiBold" FontSize="14" Foreground="#333333"/>
                                </Border>
                                <WrapPanel Margin="10" VerticalAlignment="Center">
                                    <TextBlock Text="Запрос:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13" Foreground="#555555"/>
                                    <ComboBox x:Name="CmbAnalyticsQuery" Width="400" Height="32" Margin="0,0,15,0" SelectionChanged="CmbAnalyticsQuery_SelectionChanged"/>
                                    <Button x:Name="BtnExecuteQuery" Content="▶️ Выполнить" Width="120" Height="32" 
                            Background="#2196F3" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="BtnExecuteQuery_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Дополнительные параметры для запросов -->
                        <Border Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,10" Padding="0" 
                x:Name="PanelQueryParams" Visibility="Collapsed" Grid.Row="1">
                            <StackPanel>
                                <Border Background="#F5F5F5" Padding="10,8" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
                                    <TextBlock Text="⚙️ Параметры запроса" FontWeight="SemiBold" FontSize="14" Foreground="#333333"/>
                                </Border>
                                <StackPanel x:Name="QueryParamsPanel" Orientation="Horizontal" Margin="10"/>
                            </StackPanel>
                        </Border>

                        <!-- Результат запроса -->
                        <Border Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,0,0" Padding="0" Grid.Row="2" Grid.RowSpan="2">
                            <StackPanel>
                                <Border Background="#F5F5F5" Padding="10,8" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
                                    <TextBlock Text="📊 Результат" FontWeight="SemiBold" FontSize="14" Foreground="#333333"/>
                                </Border>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="10">
                                    <DataGrid x:Name="DgAnalyticsResult" 
          AutoGenerateColumns="True" 
          IsReadOnly="True" 
          Background="White" 
          MinHeight="400" 
          CanUserSortColumns="True"
          LoadingRow="DgAnalyticsResult_LoadingRow"
          AutoGeneratingColumn="DgAnalyticsResult_AutoGeneratingColumn"
          AutoGeneratedColumns="DgAnalyticsResult_AutoGeneratedColumns"
          ScrollViewer.HorizontalScrollBarVisibility="Auto"
          ScrollViewer.VerticalScrollBarVisibility="Auto"
          HorizontalAlignment="Stretch"
          HorizontalContentAlignment="Stretch">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Height" Value="45"/>
                                                <Setter Property="MinHeight" Value="45"/>
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                                <Setter Property="Padding" Value="8,5"/>
                                                <Setter Property="FontSize" Value="12.5"/>
                                            </Style>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="MinHeight" Value="35"/>
                                                <Setter Property="Padding" Value="8,5"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                <Setter Property="FontSize" Value="12"/>
                                            </Style>
                                        </DataGrid.Resources>
                                    </DataGrid>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</Window>