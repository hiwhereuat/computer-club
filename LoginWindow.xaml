<Window x:Class="computerclub.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="571" Width="520" 
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        ResizeMode="NoResize" Background="#F0F2F5">

    <Grid Margin="0,0,0,49">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="#2196F3" Grid.Row="0">
            <Grid>
                <TextBlock Text="COMPUTER CLUB" FontSize="18" FontWeight="Bold" Foreground="White" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Content="✕" Width="35" Height="35" FontSize="16" FontWeight="Bold" 
                        Foreground="White" Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0"
                        Click="CloseWindow_Click" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Форма входа -->
        <Border Grid.Row="1" Margin="30">
            <StackPanel VerticalAlignment="Center">

                <!-- Логотип -->
                <TextBlock Text="🎮" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Вход в систему" FontSize="24" FontWeight="SemiBold" 
                           HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="#333"/>

                <!-- Логин -->
                <TextBlock Text="Логин" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#555"/>
                <TextBox x:Name="TxtLogin" Height="40" Padding="10,0" FontSize="14" Margin="0,0,0,15">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="BorderBrush" Value="#D0D0D0"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Пароль -->
                <TextBlock Text="Пароль" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#555"/>
                <PasswordBox x:Name="TxtPassword" Height="40" Padding="10,0" FontSize="14" Margin="0,0,0,20">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox">
                            <Setter Property="BorderBrush" Value="#D0D0D0"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>

                <!-- Кнопка входа -->
                <Button Content="Войти" Height="45" FontSize="14" FontWeight="SemiBold" 
                        Background="#2196F3" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="Login_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2196F3"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Статус -->
                <TextBlock x:Name="TxtStatus" Text="" FontSize="12" Foreground="#F44336" 
                           HorizontalAlignment="Center" Margin="0,15,0,0"/>

                
            </StackPanel>
        </Border>
    </Grid>
</Window>